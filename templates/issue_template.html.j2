<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title>Ekurhuleni Underground — Issue {{ issue }}: {{ title }}</title>
<meta name="description" content="{{ deck }}">
<meta property="og:type" content="article">
<meta property="og:site_name" content="Ekurhuleni Underground">
<meta property="og:title" content="Issue {{ issue }}: {{ title }}">
<meta property="og:description" content="{{ deck }}">
<meta property="og:locale" content="en_ZA">
<style>
:root {
  --gold:       #B8963E;
  --dark:       #1A1A1A;
  --mid:        #555555;
  --light:      #888888;
  --bg:         #FAFAF7;
  --rule:       #DDDDDD;
  --tint:       #F5F0E8;
  --tint-hover: #EDE8DF;
  --safe-l: env(safe-area-inset-left,   0px);
  --safe-r: env(safe-area-inset-right,  0px);
  --safe-b: env(safe-area-inset-bottom, 0px);
}
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { -webkit-text-size-adjust: 100%; text-size-adjust: 100%; scroll-behavior: smooth; }
body {
  background: var(--bg); color: var(--dark);
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 16px; line-height: 1.75;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility; overflow-x: hidden;
}
a, button { touch-action: manipulation; }
img { max-width: 100%; height: auto; display: block; }
.page-wrap {
  max-width: 720px; margin: 0 auto;
  padding: 0 16px 72px;
  padding-left:  calc(16px + var(--safe-l));
  padding-right: calc(16px + var(--safe-r));
  padding-bottom: calc(72px + var(--safe-b));
}
/* NAV */
.top-nav {
  border-bottom: 1px solid var(--rule); padding: 0;
  display: flex; justify-content: space-between;
  align-items: stretch; position: relative; min-height: 44px;
}
.nav-brand {
  font-family: Arial, sans-serif; font-size: 11px; font-weight: 700;
  letter-spacing: .14em; color: var(--gold); text-transform: uppercase;
  text-decoration: none; display: flex; align-items: center; padding: 10px 0;
}
.nav-links {
  display: none; position: absolute; top: 100%; right: 0;
  flex-direction: column; list-style: none; background: var(--bg);
  border: 1px solid var(--rule); border-top: 3px solid var(--gold);
  min-width: 180px; z-index: 200; box-shadow: 0 6px 20px rgba(0,0,0,.10);
}
.nav-links.is-open { display: flex; }
.nav-links li { border-bottom: 1px solid var(--rule); }
.nav-links li:last-child { border-bottom: none; }
.nav-links li a {
  font-family: Arial, sans-serif; font-size: 13px; font-weight: 700;
  letter-spacing: .06em; text-transform: uppercase; color: var(--mid);
  text-decoration: none; display: flex; align-items: center;
  padding: 0 20px; min-height: 48px; transition: color 0.12s, background 0.12s;
}
.nav-links li a:hover, .nav-links li a.active { color: var(--gold); background: var(--tint); }
.nav-toggle {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; gap: 5px; width: 44px; height: 44px;
  background: none; border: none; cursor: pointer; padding: 0; flex-shrink: 0;
}
.nav-toggle span {
  display: block; width: 22px; height: 2px; background: var(--mid);
  border-radius: 1px; transition: transform 0.22s ease, opacity 0.22s ease;
  transform-origin: center; pointer-events: none;
}
.nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.nav-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
/* HEADER */
.site-header {
  border-bottom: 3px solid var(--gold); padding: 14px 0 10px;
  display: flex; justify-content: space-between; align-items: baseline;
}
.site-header .pub-name {
  font-family: Arial, sans-serif; font-size: 12px; font-weight: 700;
  letter-spacing: .12em; color: var(--gold); text-transform: uppercase;
}
.site-header .issue-meta { font-family: Arial, sans-serif; font-size: 12px; color: var(--light); }
/* MASTHEAD */
.masthead { text-align: center; padding: 36px 0 28px; border-bottom: 1px solid var(--rule); }
.masthead h1 {
  font-family: Arial, sans-serif; font-size: clamp(34px, 10vw, 64px);
  font-weight: 900; letter-spacing: .06em; color: var(--dark); line-height: 1;
}
.masthead h1 span { color: var(--gold); display: block; }
.masthead .tagline { font-style: italic; color: var(--mid); margin-top: 12px; font-size: 15px; }
/* LABELS */
.label {
  font-family: Arial, sans-serif; font-size: 11px; font-weight: 700;
  letter-spacing: .16em; text-transform: uppercase; color: var(--gold);
  margin-top: 44px; margin-bottom: 8px; display: block;
}
/* THEME BLOCK */
.theme-block {
  background: var(--tint); border-left: 4px solid var(--gold);
  padding: 24px 28px; margin: 28px 0 32px;
}
.theme-block h2 {
  font-family: Arial, sans-serif; font-size: 22px; font-weight: 700;
  color: var(--dark); margin-bottom: 4px;
}
.theme-block .sub { font-style: italic; color: var(--mid); font-size: 15px; margin-bottom: 18px; }
.theme-block p { margin-bottom: 14px; font-size: 16px; color: var(--mid); }
.theme-block p:last-child { margin-bottom: 0; }
/* ISSUE TITLE */
.issue-title { padding: 36px 0 28px; border-bottom: 1px solid var(--rule); }
.issue-title h2 {
  font-family: Arial, sans-serif; font-size: clamp(26px, 5vw, 40px);
  font-weight: 900; color: var(--dark); line-height: 1.15; margin-bottom: 14px;
}
.issue-title .deck { font-style: italic; font-size: 19px; color: var(--mid); line-height: 1.55; }
/* SECTION HEAD */
.section-head {
  font-family: Arial, sans-serif; font-size: 18px; font-weight: 700;
  font-style: italic; color: var(--dark); border-bottom: 3px solid var(--gold);
  padding-bottom: 8px; margin-bottom: 22px;
}
/* BODY COPY */
p.body { margin-bottom: 20px; text-align: justify; }
/* PULL QUOTE */
blockquote.pull {
  border-top: 3px solid var(--gold); border-bottom: 3px solid var(--gold);
  padding: 22px 32px; margin: 36px 0; font-style: italic; font-size: 20px;
  font-weight: 700; color: var(--gold); text-align: center; line-height: 1.5;
}
/* ESSAY SECTION LABEL */
.essay-section-label {
  font-family: Arial, sans-serif; font-size: 12px; font-weight: 700;
  letter-spacing: .1em; text-transform: uppercase; color: var(--gold); margin: 36px 0 10px;
}
/* MICRO PROFILE */
.micro { margin-bottom: 32px; padding-top: 20px; border-top: 1px solid var(--rule); }
.micro:first-of-type { border-top: none; padding-top: 0; }
.micro-title { font-family: Arial, sans-serif; font-size: 17px; font-weight: 700; color: var(--dark); margin-bottom: 2px; }
.micro-title span { color: var(--gold); }
.micro-loc {
  font-family: Arial, sans-serif; font-size: 11px; font-weight: 700;
  letter-spacing: .1em; text-transform: uppercase; color: var(--light); margin-bottom: 10px;
}
/* MAP COORDS */
.coords {
  font-family: Arial, sans-serif; font-size: 13px; font-weight: 700;
  letter-spacing: .08em; color: var(--gold); margin-bottom: 16px;
}
/* BIG NUMBER */
.big-number {
  text-align: center; padding: 32px 0 24px;
  border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); margin: 8px 0 28px;
}
.big-number .num {
  font-family: Arial, sans-serif; font-size: clamp(36px, 7vw, 56px);
  font-weight: 900; color: var(--gold); line-height: 1; display: block; margin-bottom: 8px;
}
.big-number .num-label {
  font-family: Arial, sans-serif; font-size: 14px; font-weight: 700;
  color: var(--mid); text-transform: uppercase; letter-spacing: .06em;
}
/* CLOSING */
.byline { font-style: italic; color: var(--mid); font-size: 15px; text-align: right; margin-top: 28px; }
.next-issue {
  border-top: 1px solid var(--rule); margin-top: 32px; padding-top: 18px;
  font-style: italic; font-size: 15px; color: var(--light);
}
/* FOOTER */
.site-footer {
  border-top: 1px solid var(--rule); padding: 24px 0 0; margin-top: 60px;
  font-family: Arial, sans-serif; font-size: 12px; color: var(--light); text-align: center;
}
.site-footer a { color: var(--gold); text-decoration: none; }
.site-footer a:hover { text-decoration: underline; }
.footer-links { display: flex; justify-content: center; flex-wrap: wrap; gap: 12px 18px; margin-top: 10px; }
.footer-copy { margin-top: 10px; font-size: 11px; }
hr.rule { border: none; border-top: 1px solid var(--rule); margin: 44px 0; }
/* RESPONSIVE */
@media (min-width: 480px) {
  body { font-size: 17px; }
  .page-wrap { padding: 0 24px 80px; }
  .masthead { padding: 48px 0 32px; }
}
@media (min-width: 640px) {
  .nav-toggle { display: none; }
  .nav-links {
    display: flex !important; flex-direction: row; position: static;
    background: none; border: none; box-shadow: none; min-width: 0; gap: 24px; align-items: center;
  }
  .nav-links li { border-bottom: none; }
  .nav-links li a { font-size: 12px; padding: 0; min-height: 44px; }
  .nav-links li a:hover, .nav-links li a.active { background: none; color: var(--gold); }
}
@media (max-width: 480px) { blockquote.pull { padding: 16px 18px; font-size: 18px; } }
@media (prefers-color-scheme: dark) {
  :root { --bg: #111110; --dark: #F0EDE6; --mid: #A8A29E; --light: #6B6863; --rule: #2C2C2A; --tint: #1C1B18; --tint-hover: #242320; }
}
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
}
</style>
</head>
<body>
<div class="page-wrap">

  <nav class="top-nav" aria-label="Main navigation">
    <a href="index.html" class="nav-brand" aria-label="Ekurhuleni Underground — home">Ekurhuleni Underground</a>
    <button class="nav-toggle" aria-controls="main-nav" aria-expanded="false" aria-label="Open navigation menu">
      <span aria-hidden="true"></span><span aria-hidden="true"></span><span aria-hidden="true"></span>
    </button>
    <ul class="nav-links" id="main-nav" role="list">
      <li><a href="index.html">Home</a></li>
      <li><a href="about.html">About</a></li>
      <li><a href="index.html#archive">Archive</a></li>
      <li><a href="partners.html">Partners</a></li>
    </ul>
  </nav>

  <header class="site-header">
    <span class="pub-name">Ekurhuleni Underground</span>
    <span class="issue-meta">Issue {{ issue }} &nbsp;|&nbsp; {{ date }}</span>
  </header>

  <div class="masthead">
    <h1>EKURHULENI<span>UNDERGROUND</span></h1>
    <p class="tagline">The hidden systems of the East Rand</p>
  </div>

  <!-- THEME ANALYSIS -->
  <div class="label">Theme Analysis — Issue {{ issue }}</div>
  <div class="theme-block">
    <h2>{{ theme_name }}</h2>
    <p class="sub">{{ theme_subtitle }}</p>
    {{ theme_html | safe }}
  </div>

  <hr class="rule">

  <!-- ISSUE TITLE -->
  <div class="label">Weekly Issue — {{ date }}</div>
  <div class="issue-title">
    <h2>{{ title }}</h2>
    <p class="deck">{{ deck }}</p>
  </div>

  <!-- 1. EDITORIAL -->
  <div class="label">1. Editorial</div>
  <div class="section-head">{{ editorial_section_title }}</div>
  {{ editorial_html | safe }}

  <!-- 2. LONG ESSAY -->
  <div class="label">2. The Long Essay</div>
  <div class="section-head">{{ essay_title }}</div>

  {% for section in essay_sections %}
  <div class="essay-section-label">{{ section.label }}</div>
  {{ section.html | safe }}
  {% if section.pull_quote %}
  <blockquote class="pull">{{ section.pull_quote }}</blockquote>
  {% endif %}
  {% endfor %}

  <!-- 3. HIDDEN ECONOMY -->
  <div class="label">3. The Hidden Economy</div>
  <div class="section-head">Three Operations Nobody Is Watching</div>

  {% for profile in profiles %}
  <div class="micro">
    <div class="micro-title"><span>{{ loop.index }}.</span> {{ profile.title }}</div>
    <div class="micro-loc">{{ profile.location }}</div>
    {{ profile.html | safe }}
  </div>
  {% endfor %}

  <!-- 4. MAP -->
  <div class="label">4. The Map of the Week</div>
  <div class="section-head">{{ map_place }}</div>
  <div class="coords">{{ map_coords }}</div>
  {{ map_html | safe }}

  <!-- 5. NUMBER -->
  <div class="label">5. The East Rand Number</div>
  <div class="big-number">
    <span class="num">{{ number_value }}</span>
    <span class="num-label">{{ number_label }}</span>
  </div>
  {{ number_html | safe }}

  <!-- 6. CLOSING -->
  <div class="label">6. Closing Reflection</div>
  <div class="section-head">{{ closing_section_title }}</div>
  {{ closing_html | safe }}

  <p class="byline">{{ byline }}</p>
  <p class="next-issue">Next issue: {{ next_issue }}</p>

  <footer class="site-footer" role="contentinfo">
    <p>The hidden systems of the East Rand</p>
    <nav class="footer-links" aria-label="Footer links">
      <a href="about.html">About</a>
      <a href="index.html#archive">Archive</a>
      <a href="partners.html">Partners</a>
      <a href="privacy.html">Privacy Policy</a>
      <a href="terms.html">Terms of Use</a>
      <a href="{{ url }}">{{ url }}</a>
    </nav>
    <p class="footer-copy">© 2026 1906 Reblabs. Published weekly from Ekurhuleni, South Africa.</p>
  </footer>

</div>

<script>
(function () {
  'use strict';
  var toggle   = document.querySelector('.nav-toggle');
  var navLinks = document.getElementById('main-nav');
  if (toggle && navLinks) {
    toggle.addEventListener('click', function () {
      var open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', open ? 'false' : 'true');
      toggle.setAttribute('aria-label', open ? 'Open navigation menu' : 'Close navigation menu');
      navLinks.classList.toggle('is-open', !open);
    });
    navLinks.addEventListener('click', function (e) {
      if (e.target.tagName === 'A') { toggle.setAttribute('aria-expanded', 'false'); navLinks.classList.remove('is-open'); }
    });
    document.addEventListener('click', function (e) {
      if (!toggle.contains(e.target) && !navLinks.contains(e.target)) {
        toggle.setAttribute('aria-expanded', 'false'); navLinks.classList.remove('is-open');
      }
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') { toggle.setAttribute('aria-expanded', 'false'); navLinks.classList.remove('is-open'); toggle.focus(); }
    });
  }
}());
</script>
</body>
</html>
